PORT=3001

# Firebase (pick one auth method)
FIREBASE_PROJECT_ID=your-project-id

# Option A: path to service account JSON (recommended locally)
# Place the file at backend/firebase-service-account.json
# or set a custom path:
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccount.json

# Option B: paste the full service account JSON as a single line (good for Render)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
